# ============================================================
# YoloHome Gateway - Biến môi trường (TEMPLATE)
# SAO CHÉP file này thành .env và điền thông tin thực
# KHÔNG commit file .env lên git!
# ============================================================

ADAFRUIT_USERNAME=your_adafruit_username
ADAFRUIT_AIO_KEY=your_adafruit_aio_key

# Tùy chọn: Gemini API Key (cho RAG Assistant)
GEMINI_API_KEY=your_gemini_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Web Auth
WEB_USERNAME=admin
WEB_PASSWORD=change_me
WEB_PORT=8000
WEB_SESSION_TTL=28800

# Weather API
OPENWEATHER_API_KEY=your_openweather_key
OPENWEATHER_CITY=Ho Chi Minh City

# Phase 5 - Database backend
DATABASE_BACKEND=sqlite
DATABASE_PATH=data/yolohome.db

# PostgreSQL (dùng khi DATABASE_BACKEND=postgresql)
POSTGRES_DSN=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=yolohome
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Phase 5 - Persistent rate limiting
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECS=300
REDIS_URL=redis://localhost:6379/0

# Phase 5 - Observability
LOG_STRUCTURED=1
METRICS_ENABLED=1
TRACING_ENABLED=0
OTLP_ENDPOINT=http://localhost:4318/v1/traces
